{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "config/**/*.ts",
    "fixtures/**/*.ts",
    "helpers/**/*.ts",
    "hooks/**/*.ts",
    "pages/**/*.ts",
    "step-definitions/**/*.ts"
  ]
}
